"""
initial layout for about us page - AI helped with scaffold needs more work
"""

<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>About Us | Sisters Road to Freedom Inc.</title>
<style>
  :root{
    --cream:#faf8f2;
    --purple:#5c3d7a;
    --purple-dark:#432a5c;
    --coral:#e0704a;
    --coral-dark:#c65a37;
    --olive:#8a9a4e;
    --olive-dark:#71812f;
    --ink:#2b2620;
    --grey:#f0eee8;
    --grey-line:#ded9cd;
  }

  *{box-sizing:border-box;}
  body{
    margin:0;
    font-family: 'Georgia', 'Times New Roman', serif;
    color:var(--ink);
    background:var(--cream);
    line-height:1.6;
  }
  h1,h2,h3,h4{
    font-family:'Georgia', serif;
    font-weight:400;
    margin:0 0 0.5em 0;
  }
  p{margin:0 0 1em 0;}
  a{color:inherit;text-decoration:none;}
  img{max-width:100%;display:block;}
  .container{max-width:1100px;margin:0 auto;padding:0 24px;}

  /* ---------- Header ---------- */
  header.site-header{
    background:#fff;
    padding:18px 0;
    border-bottom:1px solid var(--grey-line);
  }
  .header-inner{
    display:flex;
    align-items:center;
    justify-content:space-between;
    flex-wrap:wrap;
    gap:16px;
  }
  .logo{
    font-size:22px;
    font-weight:700;
    color:var(--purple);
    letter-spacing:0.3px;
  }
  nav.main-nav ul{
    list-style:none;
    display:flex;
    gap:28px;
    margin:10px 0 0 0;
    padding:0;
    font-size:14px;
    letter-spacing:0.3px;
  }
  nav.main-nav a{
    text-transform:uppercase;
    font-size:12.5px;
  }
  nav.main-nav a.active, nav.main-nav a:hover{
    color:var(--coral);
  }
  .header-actions{
    display:flex;
    align-items:center;
    gap:18px;
    font-size:13px;
  }
  .lang-toggle span{cursor:pointer;}
  .lang-toggle span.active{font-weight:700;text-decoration:underline;}
  .btn{
    display:inline-block;
    padding:11px 26px;
    border-radius:24px;
    font-family:Arial, Helvetica, sans-serif;
    font-size:13.5px;
    letter-spacing:0.3px;
    cursor:pointer;
    border:none;
  }
  .btn-donate{
    background:var(--coral);
    color:#fff;
  }
  .btn-donate:hover{background:var(--coral-dark);}
  .btn-olive{
    background:var(--olive);
    color:#fff;
  }
  .btn-olive:hover{background:var(--olive-dark);}

  /* ---------- Page Hero ---------- */
  .page-hero{
    position:relative;
    background:linear-gradient(rgba(43,38,32,0.45), rgba(43,38,32,0.45)),
      url('https://images.unsplash.com/photo-1593113630400-ea4288922497?q=80&w=1600&auto=format&fit=crop') center/cover no-repeat;
    color:#fff;
    padding:110px 0;
  }
  .page-hero h1{
    font-size:44px;
    max-width:640px;
  }
  .page-hero p.eyebrow{
    font-family:Arial, Helvetica, sans-serif;
    text-transform:uppercase;
    letter-spacing:2px;
    font-size:12.5px;
    color:#f2d9cd;
    margin-bottom:14px;
  }

  /* ---------- Mission / Story ---------- */
  .story-section{
    padding:80px 0;
  }
  .story-grid{
    display:grid;
    grid-template-columns:1.1fr 1fr;
    gap:60px;
    align-items:center;
  }
  .story-grid img{
    border-radius:6px;
  }
  .story-grid h2{
    font-size:32px;
    color:var(--purple);
    margin-bottom:20px;
  }

  /* ---------- Values ---------- */
  .values-section{
    background:var(--grey);
    padding:80px 0;
  }
  .section-heading{
    text-align:center;
    max-width:640px;
    margin:0 auto 50px auto;
  }
  .section-heading h2{
    font-size:30px;
    color:var(--purple);
  }
  .values-grid{
    display:grid;
    grid-template-columns:repeat(3, 1fr);
    gap:30px;
  }
  .value-card{
    background:#fff;
    padding:34px 28px;
    border-radius:6px;
    text-align:left;
    border-top:4px solid var(--olive);
  }
  .value-card h3{
    font-size:19px;
    color:var(--purple-dark);
    margin-bottom:10px;
  }
  .value-card p{
    font-family:Arial, Helvetica, sans-serif;
    font-size:14.5px;
    color:#514b40;
    margin:0;
  }

  /* ---------- Timeline ---------- */
  .history-section{
    padding:80px 0;
  }
  .timeline{
    max-width:760px;
    margin:0 auto;
    border-left:2px solid var(--grey-line);
    padding-left:36px;
  }
  .timeline-item{
    position:relative;
    padding-bottom:44px;
  }
  .timeline-item:last-child{padding-bottom:0;}
  .timeline-item::before{
    content:'';
    position:absolute;
    left:-44px;
    top:4px;
    width:14px;
    height:14px;
    border-radius:50%;
    background:var(--coral);
    border:3px solid var(--cream);
  }
  .timeline-year{
    font-family:Arial, Helvetica, sans-serif;
    font-weight:700;
    color:var(--coral-dark);
    font-size:13px;
    letter-spacing:1px;
    text-transform:uppercase;
    margin-bottom:6px;
  }
  .timeline-item h3{
    font-size:20px;
    margin-bottom:8px;
    color:var(--purple);
  }
  .timeline-item p{
    font-family:Arial, Helvetica, sans-serif;
    font-size:14.5px;
    color:#514b40;
  }

  /* ---------- Stats ---------- */
  .stats-section{
    position:relative;
    padding:70px 0;
    background:linear-gradient(rgba(67,42,92,0.85), rgba(67,42,92,0.85)),
      url('https://images.unsplash.com/photo-1610348725531-843dff563e2c?q=80&w=1600&auto=format&fit=crop') center/cover no-repeat;
    color:#fff;
  }
  .stats-grid{
    display:grid;
    grid-template-columns:repeat(3, 1fr);
    gap:30px;
    text-align:center;
  }
  .stats-grid .num{
    font-size:40px;
    font-weight:700;
    color:#fff;
  }
  .stats-grid .label{
    font-family:Arial, Helvetica, sans-serif;
    font-size:13.5px;
    text-transform:uppercase;
    letter-spacing:0.5px;
    color:#e6d9ee;
    margin-top:6px;
  }

  /* ---------- Team ---------- */
  .team-section{
    padding:80px 0;
  }
  .team-grid{
    display:grid;
    grid-template-columns:repeat(4, 1fr);
    gap:30px;
  }
  .team-card{
    text-align:center;
  }
  .team-photo{
    width:100%;
    aspect-ratio:1/1;
    background:#d9d4c8;
    border-radius:6px;
    margin-bottom:14px;
  }
  .team-card h4{
    font-size:17px;
    color:var(--purple-dark);
    margin-bottom:2px;
  }
  .team-card .role{
    font-family:Arial, Helvetica, sans-serif;
    font-size:13px;
    color:var(--coral-dark);
    text-transform:uppercase;
    letter-spacing:0.5px;
  }

  /* ---------- CTA ---------- */
  .cta-section{
    background:var(--olive);
    color:#fff;
    text-align:center;
    padding:70px 0;
  }
  .cta-section h2{
    font-size:30px;
    margin-bottom:16px;
  }
  .cta-section p{
    font-family:Arial, Helvetica, sans-serif;
    max-width:520px;
    margin:0 auto 28px auto;
    color:#eef2e0;
  }
  .cta-buttons{
    display:flex;
    justify-content:center;
    gap:16px;
    flex-wrap:wrap;
  }
  .btn-outline{
    background:transparent;
    color:#fff;
    border:1.5px solid #fff;
  }
  .btn-outline:hover{background:rgba(255,255,255,0.15);}

  /* ---------- Footer ---------- */
  footer.site-footer{
    background:var(--grey);
    padding:60px 0 24px 0;
    font-family:Arial, Helvetica, sans-serif;
  }
  .footer-grid{
    display:grid;
    grid-template-columns:repeat(3, 1fr);
    gap:40px;
    margin-bottom:40px;
  }
  .footer-grid h4{
    font-size:14px;
    text-transform:uppercase;
    letter-spacing:0.5px;
    color:var(--purple);
    margin-bottom:14px;
    font-family:Arial, Helvetica, sans-serif;
  }
  .footer-grid ul{
    list-style:none;
    margin:0;
    padding:0;
    font-size:13.5px;
    color:#5a5346;
  }
  .footer-grid ul li{margin-bottom:8px;}
  .footer-bottom{
    border-top:1px solid var(--grey-line);
    padding-top:20px;
    text-align:center;
    font-size:12.5px;
    color:#7a7365;
  }

  /* ---------- Responsive ---------- */
  @media (max-width:900px){
    nav.main-nav{display:none;}
    .story-grid{grid-template-columns:1fr;}
    .story-grid .story-img{order:-1;}
    .values-grid{grid-template-columns:1fr;}
    .stats-grid{grid-template-columns:1fr;gap:36px;}
    .team-grid{grid-template-columns:repeat(2,1fr);}
    .footer-grid{grid-template-columns:1fr;gap:28px;}
    .page-hero{padding:70px 0;}
    .page-hero h1{font-size:32px;}
  }
</style>
</head>
<body>

<header class="site-header">
  <div class="container header-inner">
    <div class="logo">Sister Road to Freedom Inc.</div>
    <nav class="main-nav">
      <ul>
        <li><a href="#" class="active">About Us</a></li>
        <li><a href="#">Our Impact</a></li>
        <li><a href="#">Program</a></li>
        <li><a href="#">Get Involved</a></li>
        <li><a href="#">Contact Us</a></li>
      </ul>
    </nav>
    <div class="header-actions">
      <div class="lang-toggle"><span class="active">EN</span> | <span>ES</span></div>
      <button class="btn btn-donate">Donate</button>
    </div>
  </div>
</header>

<section class="page-hero">
  <div class="container">
    <p class="eyebrow">About Us</p>
    <h1>Rooted in Community. Driven by Dignity.</h1>
  </div>
</section>

<section class="story-section">
  <div class="container story-grid">
    <div>
      <h2>Our Story</h2>
      <p>Sisters Road to Freedom Inc. began with a simple belief: no family in Lexington should have to choose between groceries and other basic needs. What started as a small, neighbor-to-neighbor effort has grown into a trusted resource for individuals and families across our community.</p>
      <p>Today, we provide food, essential supplies, and compassionate support to help every person we serve move forward with dignity and hope. We know that lasting change happens through relationships, not transactions &mdash; so we take the time to listen, to understand, and to walk alongside the people we serve.</p>
    </div>
    <div class="story-img">
      <img src="https://images.unsplash.com/photo-1593113646773-028c64a8f1b8?q=80&w=900&auto=format&fit=crop" alt="Volunteers packing fresh produce for families">
    </div>
  </div>
</section>

<section class="values-section">
  <div class="container">
    <div class="section-heading">
      <h2>What Guides Us</h2>
      <p>Everything we do is grounded in a few simple commitments.</p>
    </div>
    <div class="values-grid">
      <div class="value-card">
        <h3>Dignity First</h3>
        <p>Every person who comes to us is treated with respect and choice, never charity as an afterthought.</p>
      </div>
      <div class="value-card">
        <h3>Community-Rooted</h3>
        <p>We work hand-in-hand with local organizations and ministries who know our neighbors best.</p>
      </div>
      <div class="value-card">
        <h3>Whole-Person Care</h3>
        <p>Food is where we start, not where we stop &mdash; we connect families to the resources they need to thrive.</p>
      </div>
    </div>
  </div>
</section>

<section class="history-section">
  <div class="container">
    <div class="section-heading">
      <h2>Our Journey</h2>
    </div>
    <div class="timeline">
      <div class="timeline-item">
        <div class="timeline-year">Year One</div>
        <h3>A Grassroots Beginning</h3>
        <p>A small group of volunteers began distributing food from a single location, serving a handful of Lexington families each week.</p>
      </div>
      <div class="timeline-item">
        <div class="timeline-year">Growing Reach</div>
        <h3>Expanding Across Zip Codes</h3>
        <p>As word spread, we formalized as a nonprofit and expanded our reach to families across 12 zip codes in the greater Lexington area.</p>
      </div>
      <div class="timeline-item">
        <div class="timeline-year">Today</div>
        <h3>A Trusted Community Partner</h3>
        <p>We now support more than 2,600 families alongside 10+ community partners, and we're just getting started.</p>
      </div>
    </div>
  </div>
</section>

<section class="stats-section">
  <div class="container">
    <div class="stats-grid">
      <div>
        <div class="num">12</div>
        <div class="label">Zip Codes Reached</div>
      </div>
      <div>
        <div class="num">2600+</div>
        <div class="label">Families Supported</div>
      </div>
      <div>
        <div class="num">10+</div>
        <div class="label">Community Partners</div>
      </div>
    </div>
  </div>
</section>

<section class="team-section">
  <div class="container">
    <div class="section-heading">
      <h2>Meet Our Team</h2>
      <p>The people who make this work possible, every single day.</p>
    </div>
    <div class="team-grid">
      <div class="team-card">
        <div class="team-photo"></div>
        <h4>Name Here</h4>
        <div class="role">Executive Director</div>
      </div>
      <div class="team-card">
        <div class="team-photo"></div>
        <h4>Name Here</h4>
        <div class="role">Program Director</div>
      </div>
      <div class="team-card">
        <div class="team-photo"></div>
        <h4>Name Here</h4>
        <div class="role">Volunteer Coordinator</div>
      </div>
      <div class="team-card">
        <div class="team-photo"></div>
        <h4>Name Here</h4>
        <div class="role">Board Chair</div>
      </div>
    </div>
  </div>
</section>

<section class="cta-section">
  <div class="container">
    <h2>Join Us on the Road to Freedom</h2>
    <p>Whether through a donation, a partnership, or your time, there's a place for you in this work.</p>
    <div class="cta-buttons">
      <button class="btn btn-donate">Donate Today</button>
      <button class="btn btn-outline">Get Involved</button>
    </div>
  </div>
</section>

<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <div>
        <h4>About Us</h4>
        <ul>
          <li>Mission</li>
          <li>Our Impact</li>
          <li>Reports</li>
          <li>Program</li>
        </ul>
      </div>
      <div>
        <h4>Get Involved</h4>
        <ul>
          <li>Donate</li>
          <li>Give Items</li>
          <li>Partner With Us</li>
        </ul>
      </div>
      <div>
        <h4>Connect With Us</h4>
        <ul>
          <li>141 2 N Broadway #206, Lexington, KY 40525</li>
          <li>(859) 539-7677</li>
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      Sisters Road to Freedom, Inc. is a 501(c)(3) corporation. EIN #00-0735886.
    </div>
  </div>
</footer>

</body>
</html>
